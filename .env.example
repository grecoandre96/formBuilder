# Database (Railway Postgres or local Docker)
DATABASE_URL="postgresql://user:password@localhost:5432/formbuilder"

# Anthropic API key (https://console.anthropic.com/)
AI_KEY="sk-ant-api03-..."

# Admin password for the dashboard
APP_PASSWORD="change-me"

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET="change-me-32-random-chars"

# Public base URL (used for file attachment URLs in webhook payloads)
NEXT_PUBLIC_BASE_URL="https://your-domain.railway.app"
